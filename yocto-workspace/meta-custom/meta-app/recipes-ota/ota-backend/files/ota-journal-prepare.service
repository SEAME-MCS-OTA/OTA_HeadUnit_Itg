[Unit]
Description=Prepare persistent journal directory on /data
DefaultDependencies=no
After=local-fs.target
Before=systemd-journald.service
Wants=local-fs.target
RequiresMountsFor=/data

[Service]
Type=oneshot
ExecStart=/usr/sbin/ota-journal-prepare.sh
RemainAfterExit=yes

[Install]
WantedBy=sysinit.target
